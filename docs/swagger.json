  "info": {
    "title": "Meal Magic Delivery API",
    "description": "REST API for shops, products, coupons and orders",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "shops",
      "description": ""
    },
    {
      "name": "products",
      "description": ""
    },
    {
      "name": "categories",
      "description": ""
    },
    {
      "name": "orders",
      "description": ""
    },
    {
      "name": "coupons",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "CreateShopDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Best Burgers"
          },
          "imageUrl": {
            "type": "string"
          },
          "rating": {
            "type": "number",
            "example": 4.5
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateShopDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "rating": {
            "type": "number"
          }
        }
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Big Burger"
          },
          "price": {
            "type": "number",
            "example": 9.99
          },
          "imageUrl": {
            "type": "string"
          },
          "shopId": {
            "type": "string"
          },
          "categoryId": {
            "type": "string"
          },
          "discountPercent": {
            "type": "number",
            "example": 0
          }
        },
        "required": [
          "name",
          "price",
          "shopId",
          "categoryId"
        ]
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "imageUrl": {
            "type": "string"
          },
          "categoryId": {
            "type": "string"
          },
          "discountPercent": {
            "type": "number"
          }
        }
      },
      "OrderItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "price": {
            "type": "number"
          }
        },
        "required": [
          "productId",
          "quantity",
          "price"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "totalPrice": {
            "type": "number"
          },
          "couponCode": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemDto"
            }
          }
        },
        "required": [
          "email",
          "phone",
          "address",
          "totalPrice",
          "items"
        ]
      },
      "CreateCouponDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Summer Sale"
          },
          "code": {
            "type": "string",
            "example": "SUMMER20"
          },
          "discountPercent": {
            "type": "number",
            "example": 20
          },
          "imageUrl": {
            "type": "string"
          },
          "active": {
            "type": "boolean",
            "default": true
          }
        },
        "required": [
          "name",
          "code",
          "discountPercent"
        ]
      },
      "UpdateCouponDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "discountPercent": {
            "type": "number"
          },
          "imageUrl": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Burgers"
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Pizza"
          }
        }
      }
    }
  }
}